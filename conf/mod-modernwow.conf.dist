########################################
# mod-modernWoW Configuration File
########################################

[worldserver]

#####################################
# GENERAL
#####################################

# Enable/Disable the entire mod-modernWoW module
# Default: 1 (enabled)
ModernWoW.Enable = 1

# Announce module load on startup
# Default: 1 (enabled)
ModernWoW.Announce = 1

#####################################
# AUTO-LOOT
#####################################

# Automatically loot all items from a corpse on open
# 0 = disabled (vanilla behavior)
# 1 = auto-loot all items
# 2 = auto-loot only items below quality threshold
# Default: 1
ModernWoW.AutoLoot.Enable = 1

# Quality threshold for auto-loot mode 2 (0=Poor, 1=Common, 2=Uncommon, 3=Rare, 4=Epic)
# Default: 1 (auto-loot Poor and Common, manual for Uncommon+)
ModernWoW.AutoLoot.Threshold = 1

# Auto-loot gold as well
# Default: 1 (enabled)
ModernWoW.AutoLoot.Gold = 1

#####################################
# DYNAMIC CREATURE SCALING
#####################################

# Enable dynamic creature level scaling
# Creatures will scale to player level in all zones
# Default: 1 (enabled)
ModernWoW.DynamicScaling.Enable = 1

# Scaling mode — determines how combat is balanced between players and creatures
#
# Mode 1 — Real Numbers (HP Upscaling):
#   Creature HP is scaled UP to the highest-level player attacking it.
#   Player outgoing damage is NOT modified — players always see their real numbers.
#   Higher-level players kill the mob faster than lower-level players.
#   Best for: servers where character power progression should feel meaningful.
#
# Mode 2 — Equal TTK (Damage Downscaling):
#   Creature HP stays at template value. Each player's damage is scaled DOWN
#   per-player using CreatureBaseStats ratios so all players kill the mob in
#   roughly the same number of hits. Similar to classic Chromie Time zone scaling.
#   Best for: mixed-level groups questing together on equal footing.
#
# Mode 3 — Compromise (Party Average):
#   Creature HP is scaled to the average level of the attacking players.
#   Each player's damage is adjusted relative to that average HP pool.
#   Higher-level players contribute more, but not overwhelmingly so.
#   Best for: a middle ground between modes 1 and 2.
#
# Default: 2
ModernWoW.DynamicScaling.Mode = 2

# Minimum creature level (floor) - do not scale below this
# Default: 1
ModernWoW.DynamicScaling.MinLevel = 1

# Maximum creature level (ceiling)
# Default: 80
ModernWoW.DynamicScaling.MaxLevel = 80

# Health scaling multiplier relative to level difference
# Default: 1.0
ModernWoW.DynamicScaling.HealthMultiplier = 1.0

# Damage scaling multiplier relative to level difference
# Default: 1.0
ModernWoW.DynamicScaling.DamageMultiplier = 1.0

# Scale XP reward along with level
# Default: 1 (enabled)
ModernWoW.DynamicScaling.ScaleXP = 1

# Scale loot quality along with level
# Default: 1 (enabled)
ModernWoW.DynamicScaling.ScaleLoot = 1

# Blacklisted map IDs (comma separated) - scaling disabled in these
# Example: "509,469" (AQ40, BWL)
# Default: "" (all maps scaled)
ModernWoW.DynamicScaling.MapBlacklist = ""

# Blacklist raid instances from scaling
# Default: 1 (raids not scaled)
ModernWoW.DynamicScaling.ExcludeRaids = 1

#####################################
# PERSONAL LOOT
#####################################

# Enable Personal Loot mode for groups
# 0 = disabled (vanilla group loot)
# 1 = personal loot for all group content
# 2 = personal loot only in dungeons/raids
# Default: 1
ModernWoW.PersonalLoot.Enable = 1

# Personal loot bonus drop chance multiplier when alone
# Default: 1.0 (no bonus)
ModernWoW.PersonalLoot.SoloMultiplier = 1.2

#####################################
# SPELL QUEUE
#####################################

# Enable spell queue window (lag tolerance)
# Allows casting the next spell up to X ms before the GCD ends
# Default: 1 (enabled)
ModernWoW.SpellQueue.Enable = 1

# Spell queue window in milliseconds
# Default: 400
ModernWoW.SpellQueue.WindowMs = 400

#####################################
# WORLD QUESTS
#####################################

# Enable daily World Quest system
# Default: 1 (enabled)
ModernWoW.WorldQuests.Enable = 1

# Number of active world quests at a time per player
# Default: 12
ModernWoW.WorldQuests.ActiveCount = 12

# World quest duration in hours
# Default: 24
ModernWoW.WorldQuests.DurationHours = 24

#####################################
# CATCH-UP MECHANIC
#####################################

# Enable catch-up mechanic for low-level characters on an account
# that already has a max-level character
# Default: 1 (enabled)
ModernWoW.CatchUp.Enable = 1

# XP bonus multiplier for catch-up characters
# Default: 2.0 (double XP)
ModernWoW.CatchUp.XPMultiplier = 2.0

# Loot quality bonus for catch-up (0 = disabled)
# Default: 1 (enabled)
ModernWoW.CatchUp.BetterLoot = 1

#####################################
# INSTANT MAIL
#####################################

# Deliver mail instantly (no 1-hour delay)
# Default: 1 (enabled)
ModernWoW.InstantMail.Enable = 1

#####################################
# QUESTS
#####################################

# Make lower-level quests show as normal (gold exclamation mark)
# instead of low-level (silver exclamation mark) and not hidden by default.
# Default: 1 (enabled)
ModernWoW.Quests.ShowLowLevelAsNormal = 1

#####################################
# GUILD PERKS
#####################################

# Enable simplified guild perk system
# Default: 1 (enabled)
ModernWoW.GuildPerks.Enable = 1

# XP bonus granted by guild (percentage)
# Default: 10 (10% bonus guild XP)
ModernWoW.GuildPerks.XPBonus = 10

# Cash flow perk: percentage of loot gold auto-deposited to guild bank
# Default: 5 (5%)
ModernWoW.GuildPerks.CashFlow = 5

#####################################
# COMBAT PACING (Retail-like speed)
#####################################
#
# Makes combat feel faster and more dynamic, closer to retail WoW (Shadowlands+).
#
# Haste formula at lvl 80: 32.79 Haste Rating = 1% Haste
#   New cast time  = Base cast time  / (1 + Haste%)
#   New swing time = Base weapon spd / (1 + Haste%)
#   GCD minimum    = 1.0s (WotLK client hard cap — cannot go lower in a module)
#
# Example with HasteRatingBonus = 800 (+24.4% haste at lvl80):
#   Frostbolt (3.0s base):  3.0s / 1.244 = 2.41s
#   2.6s weapon swing:      2.6s / 1.244 = 2.09s  (before MeleeSpeedPct)
#   GCD:                    1.5s / 1.244 = 1.21s  (approaching 1.0s cap)
#
# Combined with typical gear haste (~400-600 rating), players effectively
# reach 35-45% total haste — close to Shadowlands baseline feel.

# Enable Combat Pacing feature
# Default: 1 (enabled)
ModernWoW.CombatPacing.Enable = 1

# Flat haste rating bonus injected for all players at login.
# Affects: spell cast time, GCD, melee swing, ranged attack speed.
# 0       = disabled (no bonus)
# 500     = +15.3% haste  (subtle improvement)
# 800     = +24.4% haste  (default — noticeable but not jarring)
# 1200    = +36.6% haste  (very fast, GCD near 1.1s with gear)
# 1640    = +50%   haste  (extreme — GCD at 1.0s cap, Frostbolt ~2.0s)
ModernWoW.CombatPacing.HasteRatingBonus = 800

# Additional melee attack speed % modifier applied on top of haste.
# This makes melee auto-attacks "feel" faster independent of spell haste.
# 0.0   = disabled
# 10.0  = 10% faster swings (subtle)
# 20.0  = 20% faster swings (default — 2.6s weapon → ~1.75s combined with haste)
# 30.0  = 30% faster swings (aggressive)
ModernWoW.CombatPacing.MeleeSpeedPct = 20.0

# Out-of-combat HP regen rate multiplier.
# Retail WoW: players recover full HP within ~5 seconds of leaving combat.
# 1.0 = vanilla rate (slow — need food/drink)
# 5.0 = default (fast but not instant; feels like retail between pulls)
# 10.0 = very fast (near-instant HP recovery)
ModernWoW.CombatPacing.OOCHealthMult = 5.0

# Out-of-combat mana regen rate multiplier.
# 1.0 = vanilla rate
# 3.0 = default (moderately faster OOC mana regen)
# 5.0 = fast (casters rarely need to drink between pulls)
ModernWoW.CombatPacing.OOCManaMult = 3.0

